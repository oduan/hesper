{
  "name": "@hesper/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @hesper/shared build && node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "typecheck": "pnpm --filter @hesper/shared build && tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest --run"
  },
  "dependencies": {
    "@hesper/shared": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
